{
  "manifest_version": 3,
  "name": "YouTube Extended Title",
  "version": "0.3.0",
  "description": "Extends YouTube browser tab titles with video metadata such as duration, views, likes or channel name.",
  "permissions": ["storage"],
  "icons": {
    "16": "icon_16.png",
    "32": "icon_32.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon_16.png",
      "32": "icon_32.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
